<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>user-list</title>
</head>
<body>
    <h1>user-list</h1>
    <ul>
        <% for(let i=0; i<users.length; i++){ %>
            <li><%= users[i].name %> - <%= users[i].age %></li>
        <% } %>
    </ul>

    <% if(isLogin){ %>
        <h3>Welcome, you are logged in!</h3>
    <% } %>  
</body>
</html>